---
import Menu from './ExtstatsNavbarMenu.astro';
import {bggMenu, devMenu, type SubMenu, userMenu, patreonMenu} from "../code/NavBase";

const blogMenu: SubMenu = { name: 'Blog', style: 'nav-blog', link: "/blog.html", items: [
        { name: "Doco", link: "/doco.html" }
    ]};
---
<div role="navigation" class="extstats-navbar">
    <a class="go-button" href="/" role="button"><img src={'/img/go.png'}  height="28px" alt="GO logo from Monopoly" title="Go directly to the Home Page"/></a>
    <a class="navbar-button clickable nav-wartable" href="/about.html">About</a>
    <a class="navbar-button clickable nav-ranking" href="https://extstats.drfriendless.com">Stats</a>
    <Menu link={blogMenu}/>
    <Menu link={userMenu}/>
    <Menu link={bggMenu}/>
    <Menu link={devMenu}/>
    <Menu link={patreonMenu}/>
    <img src="/img/No_AI_art.svg" alt="No AI" height="100%" title="No AI was used in the building of this site."/>
    <a href="/blog.xml"><img src="/img/rss.svg" alt="RSS Feed" height="100%" title="RSS Feed"></a>
</div>